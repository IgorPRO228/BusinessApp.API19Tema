<Window x:Class="BusinessApp.API19Tema.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BusinessApp.API19Tema.Client.ViewModels"
        Title="Доска объявлений" Height="550" Width="900">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Загрузить" Command="{Binding LoadCommand}" Width="80" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="80" Margin="5"/>
            <Button Content="Опубликовать" Command="{Binding PublishCommand}" Width="100" Margin="5"/>
            <CheckBox Content="Только активные" IsChecked="{Binding ShowOnlyActive}" Margin="20,5,0,5"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
            <StackPanel>
                <TextBlock Text="Добавить новое объявление" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Заголовок:" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding NewTitle}" Grid.Row="0" Grid.Column="1" Margin="5"/>
                    <TextBlock Text="Содержание:" Grid.Row="1" Grid.Column="0"/>
                    <TextBox Text="{Binding NewContent}" Grid.Row="1" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap"/>
                    <TextBlock Text="Автор:" Grid.Row="2" Grid.Column="0"/>
                    <TextBox Text="{Binding NewAuthor}" Grid.Row="2" Grid.Column="1" Margin="5"/>
                    <TextBlock Text="Срок до:" Grid.Row="3" Grid.Column="0"/>
                    <DatePicker SelectedDate="{Binding NewExpiryDate}" Grid.Row="3" Grid.Column="1" Margin="5"/>
                    <CheckBox Content="Опубликовать сразу" IsChecked="{Binding NewIsPublished}" Grid.Row="4" Grid.Column="1" Margin="5,5,0,5"/>
                </Grid>
                <Button Content="Добавить объявление" Command="{Binding AddCommand}" Width="150" Margin="5" HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Announcements}"  SelectedItem="{Binding SelectedAnnouncement}" IsReadOnly="True"  Margin="5" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="150"/>
                <DataGridTextColumn Header="Содержание" Binding="{Binding Content}" Width="250"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="120"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt}" Width="120"/>
                <DataGridTextColumn Header="Срок до" Binding="{Binding ExpiryDate}" Width="100"/>
                <DataGridCheckBoxColumn Header="Опубликовано" Binding="{Binding IsPublished}" Width="90"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>